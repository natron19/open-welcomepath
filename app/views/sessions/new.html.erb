<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-sm-10 col-md-7 col-lg-5">

      <div class="card shadow-sm">
        <div class="card-body p-4 p-md-5">

          <h1 class="h3 mb-4 text-center">Sign in</h1>

          <% if flash[:alert] %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <%= flash[:alert] %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>

          <%= form_with url: sign_in_path do |f| %>
            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email,
                    name: "email",
                    class: "form-control",
                    autofocus: true, autocomplete: "email" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label" %>
              <%= f.password_field :password,
                    name: "password",
                    class: "form-control",
                    autocomplete: "current-password" %>
            </div>

            <div class="mb-4 text-end">
              <%= link_to "Forgot your password?", new_password_path, class: "small text-muted" %>
            </div>

            <%= f.submit "Sign in", class: "btn btn-primary w-100" %>
          <% end %>

        </div>
      </div>

      <p class="text-center mt-3 text-muted small">
        Don't have an account? <%= link_to "Sign up", sign_up_path %>
      </p>

    </div>
  </div>
</div>
