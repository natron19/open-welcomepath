<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0"><code><%= @template.name %></code></h1>
    <p class="text-muted small mb-0"><%= @template.description %></p>
  </div>
  <%= link_to "← All Templates", admin_ai_templates_path, class: "btn btn-sm btn-outline-secondary" %>
</div>

<div data-controller="variable-inputs">
  <%# Editor form %>
  <%= form_with model: @template, url: admin_ai_template_path(@template), method: :patch do |f| %>
    <% if @template.errors.any? %>
      <div class="alert alert-danger">
        <% @template.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <label class="form-label">System Prompt</label>
      <%= f.text_area :system_prompt, rows: 8, class: "form-control font-monospace",
          style: "font-size: 0.85rem" %>
    </div>

    <div class="mb-3">
      <label class="form-label">
        User Prompt Template
        <span class="text-muted small ms-1">— use <code>{{variable}}</code> for inputs</span>
      </label>
      <%= f.text_area :user_prompt_template, rows: 8, class: "form-control font-monospace",
          style: "font-size: 0.85rem",
          data: { "variable-inputs-target": "template", action: "input->variable-inputs#update" } %>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-12 col-md-4">
        <label class="form-label">Model</label>
        <%= f.select :model,
            [["gemini-2.5-flash", "gemini-2.5-flash"],
             ["gemini-2.5-pro",   "gemini-2.5-pro"]],
            {}, class: "form-select" %>
      </div>
      <div class="col-12 col-md-4">
        <label class="form-label">Max Output Tokens</label>
        <%= f.number_field :max_output_tokens, min: 100, max: 8192, class: "form-control" %>
      </div>
      <div class="col-12 col-md-4" data-controller="temperature-slider">
        <label class="form-label">
          Temperature
          <span class="badge bg-secondary ms-1"
                data-temperature-slider-target="display">
            <%= @template.temperature %>
          </span>
        </label>
        <%= f.range_field :temperature, min: 0.0, max: 2.0, step: 0.1,
            class: "form-range",
            data: { "temperature-slider-target": "slider",
                    action: "input->temperature-slider#update" } %>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label">Description</label>
      <%= f.text_field :description, class: "form-control" %>
    </div>

    <div class="mb-3">
      <label class="form-label">Notes</label>
      <%= f.text_area :notes, rows: 3, class: "form-control" %>
    </div>

    <%= f.submit "Save Template", class: "btn btn-primary" %>
  <% end %>

  <%# Test panel — below the editor %>
  <hr class="my-4">

  <h5>Test This Template</h5>
  <%= form_with url: admin_test_ai_template_path(@template), method: :post,
      data: { turbo_stream: true } do |f| %>
    <div data-variable-inputs-target="container" class="mb-3">
      <%# Stimulus will populate variable inputs here %>
    </div>
    <%= f.submit "Run Test", class: "btn btn-outline-primary" %>
  <% end %>

  <div id="test-result" class="mt-3"></div>
</div>
