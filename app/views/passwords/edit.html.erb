<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-sm-10 col-md-7 col-lg-5">

      <div class="card shadow-sm">
        <div class="card-body p-4 p-md-5">

          <h1 class="h3 mb-4 text-center">Choose a new password</h1>

          <% if @user&.errors&.any? %>
            <div class="alert alert-danger">
              <% @user.errors.full_messages.each do |msg| %>
                <div><%= msg %></div>
              <% end %>
            </div>
          <% end %>

          <%= form_with url: url_for(controller: :passwords, action: :update, token: params[:token]),
                        method: :patch do |f| %>
            <div class="mb-3">
              <%= f.label :password, "New password", class: "form-label" %>
              <%= f.password_field :password,
                    name: "user[password]",
                    class: "form-control",
                    autofocus: true, autocomplete: "new-password" %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
              <%= f.password_field :password_confirmation,
                    name: "user[password_confirmation]",
                    class: "form-control",
                    autocomplete: "new-password" %>
            </div>

            <%= f.submit "Update password", class: "btn btn-primary w-100" %>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
