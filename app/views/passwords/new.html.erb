<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-sm-10 col-md-7 col-lg-5">

      <div class="card shadow-sm">
        <div class="card-body p-4 p-md-5">

          <h1 class="h3 mb-2 text-center">Reset your password</h1>
          <p class="text-muted text-center small mb-4">
            Enter your email and we'll send you a reset link.
          </p>

          <% if flash[:alert] %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <%= flash[:alert] %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>

          <%= form_with url: passwords_path do |f| %>
            <div class="mb-4">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email,
                    name: "email",
                    class: "form-control",
                    autofocus: true, autocomplete: "email",
                    placeholder: "you@example.com" %>
            </div>

            <%= f.submit "Send reset link", class: "btn btn-primary w-100" %>
          <% end %>

        </div>
      </div>

      <p class="text-center mt-3 text-muted small">
        Remember your password? <%= link_to "Sign in", sign_in_path %>
      </p>

    </div>
  </div>
</div>
